# NannyAgent Configuration File
# Location: /etc/nannyagent/config.yaml

# NannyAPI Endpoint (required)
# Default: https://api.nannyai.dev
# For local dev/testing use: http://localhost:8090
nannyapi_url: "https://api.nannyai.dev"

# Portal URL for device authorization (optional)
# Default: https://nannyai.dev
portal_url: "https://nannyai.dev"

# Token storage path (optional)
# Default: /var/lib/nannyagent/token.json
token_path: "/var/lib/nannyagent/token.json"

# Node metrics collection interval in seconds (optional)
# Default: 30
metrics_interval: 30

# Proxmox cluster/VM/LXC data collection interval in seconds (optional)
# Default: 300
proxmox_interval: 300

# ─── Refresh token renewal settings ─────────────────────────────────────────
#
# The refresh token has a 30-day lifetime. The agent automatically renews it
# before it expires so that you never have to manually re-register the agent.
#
# How it works:
#   1. Every `token_renewal_check_interval_secs` seconds the agent refreshes the
#      access token and reads `refresh_token_expires_in` from the API response.
#   2. If fewer than `token_renewal_threshold_days` days remain on the refresh
#      token, the agent calls `renew-refresh-token` to rotate it.
#   3. If that call fails (API unreachable etc.), the next attempt is scheduled
#      in `token_renewal_retry_interval_secs` seconds.  The agent never crashes.
#
# For testing you can use short intervals, e.g. 60 (1 minute).

# Days before refresh-token expiry at which renewal starts (default: 7)
token_renewal_threshold_days: 7

# Normal check cadence in seconds (default: 21600 = 6 hours)
token_renewal_check_interval_secs: 21600

# Retry interval in seconds when a renewal attempt fails (default: 3600 = 1 hour)
token_renewal_retry_interval_secs: 3600

# Debug mode (optional)
# Default: false
debug: false

# HTTP Transport Configuration (optional, advanced)
# These settings control HTTP connection behavior and error recovery.
# The agent NEVER gives up - it retries indefinitely with exponential backoff.
# http_transport:
#   max_idle_conns: 10               # Max idle connections across all hosts (default: 10)
#   max_idle_conns_per_host: 5       # Max idle connections per host (default: 5)
#   idle_conn_timeout_sec: 30        # Seconds before idle connection closed (default: 30)
#   response_header_timeout_sec: 30  # Seconds to wait for response headers
#   disable_http2: false             # Set true if experiencing HTTP/2 issues
#   transport_reset_threshold: 3     # Reset transport after N consecutive errors
#   initial_retry_delay_sec: 30      # Initial retry delay (exponential backoff)
#   max_retry_delay_sec: 1800        # Maximum retry delay (30 minutes)
